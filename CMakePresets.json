{
    "version": 9,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 30,
        "patch": 9
    },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "$env{COMMONLIBSSE_COMPILER} $env{COMMONLIBSSE_PLATFORM} $env{COMMONLIBSSE_TEXT}"
      }
    },
    {
      "name": "vcpkg",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "c:/Coding/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-skse",
        "VCPKG_HOST_TRIPLET": "x64-windows-skse",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
      }
    },
    {
      "name": "win32",
      "hidden": true,
      "environment": {
        "COMMONLIBSSE_PLATFORM": "-DWIN32_LEAN_AND_MEAN -DNOMINMAX"
      }
    },
    {
      "name": "win32-unicode",
      "hidden": true,
      "inherits": "win32",
      "environment": {
        "COMMONLIBSSE_TEXT": "-DUNICODE -D_UNICODE"
      }
    },
    {
      "name": "x64",
      "hidden": true,
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "msvc",
      "hidden": true,
      "description": "Sets the Compiler options to: ",
      "environment": {
        "COMMONLIBSSE_COMPILER": "/permissive- /Zc:preprocessor /EHsc $penv{CXXFLAGS}"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "intelliSenseMode": "windows-msvc-x64",
          "enableMicrosoftCodeAnalysis": true,
          "enableClangTidyCodeAnalysis": true
        }
      }
    },
    {
      "name": "clang-cl",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl"
      },
      "environment": {
        "COMMONLIBSSE_COMPILER": "/permissive- /EHsc -Wno-overloaded-virtual -Wno-delete-non-abstract-non-virtual-dtor -D__cpp_lib_char8_t -D__cpp_consteval -D__cpp_lib_format $penv{CXXFLAGS}"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "intelliSenseMode": "windows-clang-x64",
          "enableMicrosoftCodeAnalysis": true,
          "enableClangTidyCodeAnalysis": true
        }
      }
    },
    {
      "name": "build-tests",
      "displayName": "Build Tests",
      "hidden": true,
      "description": "Include test suites in the build.",
      "cacheVariables": {
        "BUILD_TESTS": {
          "type": "STRING",
          "value": "ON"
        }
      }
    },
    {
      "name": "msvc-debug-preset",
      "inherits": [
        "base",
        "vcpkg",
        "win32-unicode",
        "x64",
		"build-tests",
        "msvc"
      ],
      "displayName": "Debugging for MSVC",
      "description": "Debug build for MSVC testing.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug-msvc",
      "cacheVariables": {
        "CMAKE_MESSAGE_LOG_LEVEL": "DEBUG",
        "VCPKG_INSTALL_OPTIONS": "--debug",
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        },
        "buildCommandArgs": "-v"
      }
    },
    {
      "name": "msvc-release-preset",
      "inherits": [
        "base",
        "vcpkg",
        "win32-unicode",
        "x64",
		"build-tests",
        "msvc"
      ],
      "displayName": "Release for MSVC",
      "description": "Optimized MSVC release build.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Release"
        }
      }
    },
    {
      "name": "clang-cl-debug-preset",
      "inherits": [
        "base",
        "vcpkg",
        "win32-unicode",
        "x64",
		"build-tests",
        "clang-cl"
      ],
      "displayName": "Debuging for Clang-cl",
      "description": "Debug build for Clang-cl testing.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug-clang",
      "cacheVariables": {
        "CMAKE_MESSAGE_LOG_LEVEL": "DEBUG",
        "VCPKG_INSTALL_OPTIONS": "--debug",
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        }
      }
    },
    {
      "name": "clang-cl-release-preset",
      "inherits": [
        "base",
        "vcpkg",
        "win32-unicode",
        "x64",
		"build-tests",
        "clang-cl"
      ],
      "displayName": "Release for Clang-cl",
      "description": "Optimized release build for Clang-cl.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Release"
        }
      }
    },
    {
      "name": "msvc-testall-preset",
      "inherits": [
        "base",
        "vcpkg",
        "win32-unicode",
        "x64",
        "build-tests",
        "msvc"
      ],
      "displayName": "Debug All using MSVC",
      "description": "Debug build for running all tests testing.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/mscv-testall",
      "cacheVariables": {
        "CMAKE_MESSAGE_LOG_LEVEL": "DEBUG",
        "VCPKG_INSTALL_OPTIONS": "--debug",
        "CMAKE_BUILD_TYPE": {
          "type": "STRING",
          "value": "Debug"
        },
        "buildCommandArgs": "-v"
      }
    }
  ],
    "buildPresets": [
      {
        "name": "buildpreset-release-msvc",
        "displayName": "Release (MSVC)",
        "configurePreset": "msvc-release-preset",
        "description": "Optimized release build."
      },
      {
        "name": "buildpreset-debug-msvc",
        "displayName": "Debug (MSVC)",
        "configurePreset": "msvc-debug-preset",
        "description": "Debug build for testing.",
        "verbose": true
      },
      {
        "name": "buildpreset-release-clang-cl",
        "displayName": "Release (Clang)",
        "configurePreset": "clang-cl-release-preset",
        "description": "Optimized release build."
      },
      {
        "name": "buildpreset-debug-clang-cl",
        "displayName": "Debug (Clang-cl)",
        "configurePreset": "clang-cl-debug-preset",
        "description": "Debug clang-cl build for testing.",
        "verbose": true
      },
	        {
        "name": "buildpreset-debug-MSVC-TestAll",
        "displayName": "Debug-TestAll (MSVC)",
        "configurePreset": "msvc-testall-preset",
        "description": "Debug clang-cl build for testing.",
        "verbose": true
      }
    ],
    "testPresets": [
      {
        "name": "tests-all",
        "displayName": "All Tests",
        "configurePreset": "msvc-testall-preset",
        "output": {
          "outputOnFailure": true
        },
        "execution": {
          "noTestsAction": "error",
          "stopOnFailure": false
        }
      },
      {
        "name": "tests-unit",
        "displayName": "Unit Tests",
        "description": "Runs tests that do not require any Skyrim module loaded into the process.",
        "inherits": "tests-all",
        "filter": {
          "exclude": {
            "label": "[integration],[e2e]"
          }
        }
      },
        {
            "name": "tests-integration",
            "displayName": "Integration Tests",
            "description": "Runs tests that interact with a Skyrim module at rest (do not require the Skyrim module to have run any main function).",
            "inherits": "tests-all",
            "filter": {
                "include": {
                    "label": "[integration]"
                }
            }
        },
        {
            "name": "tests-e2e",
            "displayName": "End-to-End Tests",
            "description": "Runs test that depend on a fully running Skyrim engine in the process.",
            "inherits": "tests-all",
            "filter": {
                "include": {
                    "label": "[e2e]"
                }
            }
        }
    ]
}
